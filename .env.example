# Пример переменных окружения. Скопируйте в .env и заполните значениями.
# Реальные ID НЕ хранятся в репозитории.

# Базовый URL сайта (без завершающего слеша) — для canonical/OG/sitemap.
SITE_URL=https://tlk-bars.ru

# Аналитика. Если не задано — счётчики не подключаются (удобно для dev).
YM_COUNTER_ID=
GA4_ID=

# Верификация поисковых систем (содержимое meta-тегов).
YANDEX_VERIFICATION=
GOOGLE_VERIFICATION=
