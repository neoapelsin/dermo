<footer class="mt-auto border-t border-gray-200 bg-gray-50">
  <div class="container grid gap-8 py-12 md:grid-cols-3">
    <div>
      <a href="/" class="flex items-center gap-2" aria-label="{{ site.legalName }}">
        <img src="/assets/img/logo.svg" alt="{{ site.name }}" width="120" height="32" />
      </a>
      <p class="mt-4 text-sm text-gray-600">{{ site.legalName }}</p>
      {# Реквизиты-заглушки — заполняются позже через данные. #}
      <p class="mt-2 text-sm text-gray-500">ИНН: {{ site.inn }}</p>
      <p class="text-sm text-gray-500">ОГРН: {{ site.ogrn }}</p>
      <p class="text-sm text-gray-500">{{ site.address }}</p>
    </div>

    <nav aria-label="Навигация в подвале">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-900">Разделы</h2>
      <ul class="mt-4 space-y-2">
        {% for item in navigation %}
          <li><a href="{{ item.url }}" class="text-sm text-gray-600 hover:text-brand">{{ item.title }}</a></li>
        {% endfor %}
      </ul>
    </nav>

    <div>
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-900">Контакты</h2>
      <ul class="mt-4 space-y-2 text-sm text-gray-600">
        <li><a href="tel:{{ site.phoneHref }}" class="font-semibold text-brand">{{ site.phone }}</a></li>
        <li><a href="mailto:{{ site.email }}" class="hover:text-brand">{{ site.email }}</a></li>
        <li><a href="{{ site.telegram }}" class="hover:text-brand" rel="nofollow noopener" target="_blank">Telegram</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-gray-200">
    <div class="container py-4 text-center text-xs text-gray-500">
      © {{ site.legalName }}. Все права защищены.
    </div>
  </div>
</footer>
